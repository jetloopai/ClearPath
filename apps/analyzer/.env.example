# Copy this file to .env.local and fill in your values

# Anthropic (required for image-based condition assessment)
ANTHROPIC_API_KEY=sk-ant-...

# Email sending (required for lead follow-up — use Resend.com)
RESEND_API_KEY=re_...

# Google Maps (required for comps map — add to Google Cloud Console)
GOOGLE_MAPS_API_KEY=AIzaSy...
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...

# RapidAPI — Zillow scraper (required for property data + comps)
# Get from: rapidapi.com → search "Zillow"
RAPIDAPI_ZILLOW_KEY=...

# RentCast (required for rental data)
# Get from: rentcast.io
RENTCAST_API_KEY=...

# Supabase (required — get from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # safe to expose — anon/public key
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # NEVER expose client-side — server only
